apiVersion: autoscaling/v1
kind: HorizontalPodAutoscaler
metadata:
  name: pos-drugpricer-0
  namespace: pos
spec:
  maxReplicas: 10
  minReplicas: 4
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: pos-drugpricer-0
  targetCPUUtilizationPercentage: 80
---
