---
apiVersion: v1
kind: Service
metadata:
  labels:
    app: docker-local-cache
  name: docker-local-cache
spec:
  type: ClusterIP
  ports:
  - name: http
    port: 8080
    protocol: TCP
    targetPort: 8080
  selector:
    app: docker-local-cache
---
apiVersion: apps/v1
kind: Deployment
metadata:
  labels:
    app: docker-local-cache
  name: docker-local-cache
spec:
  replicas: 1
  revisionHistoryLimit: 2
  selector:
    matchLabels:
      app: docker-local-cache
  strategy:
    rollingUpdate:
      maxSurge: 25%
      maxUnavailable: 25%
    type: RollingUpdate
  template:
    metadata:
      labels:
        app: docker-local-cache
    spec:
      containers:
      - name: registry-proxy
        image: docker-local.artifactory.medimpact.com/itsystems/registry-proxy:2.8.3
        imagePullPolicy: IfNotPresent
        env:
        - name: REGISTRY_HTTP_ADDR
          value: 0.0.0.0:8080
        - name: REGISTRY_STORAGE_FILESYSTEM_ROOTDIRECTORY
          value: "/data"
        - name: REGISTRY_STORAGE_DELETE_ENABLED
          value: "true"
        - name: REGISTRY_HTTP_SECRET
          value: quahPh0eipaet0Yeih2s
        # - name: REGISTRY_PROXY_REMOTEURL
          # value: https://docker-local.artifactory.medimpact.com
        - name: REGISTRY_STORAGE_CACHE_BLOBDESCRIPTOR
          value: redis
        - name:  REGISTRY_REDIS_ADDR
          value: docker-local-cache-redis:6379
        - name:  REGISTRY_REDIS_PASSWORD
          value: "peithei8caish6uW3ooz"
        - name:  REGISTRY_REDIS_POOL_MAXIDLE
          value: "16"
        - name:  REGISTRY_REDIS_POOL_MAXACTIVE
          value: "64"
        - name:  REGISTRY_REDIS_POOL_IDLETIMEOUT
          value: "300s"
        # - name: REGISTRY_HTTP_PREFIX
          # value: /registry/
        # - name: REGISTRY_HTTP_RELATIVEURLS
          # value: "true"
        # livenessProbe:
          # failureThreshold: 3
          # httpGet:
            # path: /v2
            # port: 8080
            # scheme: HTTP
          # initialDelaySeconds: 60
          # periodSeconds: 20
          # successThreshold: 1
          # timeoutSeconds: 1
        # readinessProbe:
          # failureThreshold: 3
          # httpGet:
            # path: /v2
            # port: 8080
            # scheme: HTTP
          # initialDelaySeconds: 5
          # periodSeconds: 10
          # successThreshold: 1
          # timeoutSeconds: 1
        resources:
          limits:
            cpu: 1000m
            memory: 500Mi
          requests:
            cpu: 50m
            memory: 50Mi
        securityContext:
          allowPrivilegeEscalation: false
          capabilities:
            drop:
            - ALL
        volumeMounts:
        - name: data
          mountPath: /data
      volumes:
      - name: data
        persistentVolumeClaim:
          claimName: registry-proxy
        # emptyDir: {}
      securityContext:
        fsGroup: 1001
        runAsUser: 1001
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault